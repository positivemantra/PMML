{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/components/layout/NehruFooter": ["./src/components/nehru-portalll/layout/NehruFooter"],
      "@/components/layout/NehruHeader": ["./src/components/nehru-portalll/layout/NehruHeader"],
      "@/components/layout/NehruTopBar": ["./src/components/nehru-portalll/layout/NehruTopBar"],
      "@/components/layout/NehruMenuBar": ["./src/components/nehru-portalll/layout/NehruMenuBar"],
      "@/components/home/ChronologyTimeline": ["./src/components/nehru-portalll/home/ChronologyTimeline"],
      "@/components/home/HeroSection": ["./src/components/nehru-portalll/home/HeroSection"],
      "@/components/home/RecentUpdatesAndMedia": ["./src/components/nehru-portalll/home/RecentUpdatesAndMedia"],
      "@/components/family/FamilyTreeViewer": ["./src/components/nehru-portalll/family/FamilyTreeViewer"],
      "@/components/writings/BookReader": ["./src/components/nehru-portalll/writings/BookReader"],
      "@/context/*": ["./src/app/nehru-portal/context/*"],
      "@/data/*": ["./src/app/nehru-portal/data/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
